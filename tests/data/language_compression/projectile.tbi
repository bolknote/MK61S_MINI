10 REM PROJECTILE TRAJECTORY TABLE WITHOUT AIR RESISTANCE
20 REM INPUT SPEED ANGLE MASS AND TABLE TIME STEP
30 INPUT "SPEED",V
40 INPUT "ANGLE",A
50 INPUT "MASS",M
60 INPUT "STEP",D
70 G=9.80665
80 X=V*COS(A)
90 Y=V*SIN(A)
100 F=2*Y/G
110 R=X*F
120 H=Y*Y/(2*G)
130 K=M*V*V/2
140 PRINT "FLIGHT TIME",F
150 PRINT "RANGE",R
160 PRINT "MAX HEIGHT",H
170 PRINT "START ENERGY",K
180 PRINT "TIME","X","Y","SPEED","ENERGY"
190 FOR T=0 TO F
200 P=X*T
210 Q=Y*T-G*T*T/2
220 U=Y-G*T
230 S=SQRT(X*X+U*U)
240 E=M*S*S/2
250 PRINT T,P,Q,S,E
260 T=T+D-1
270 NEXT T
280 REM THE LOOP ADJUSTMENT ALLOWS A FRACTIONAL STEP
290 REM THE ACTIVE ANGLE SWITCH SELECTS RADIAN DEGREE OR GRADE
300 REM NEGATIVE FINAL HEIGHT MEANS THE STEP IS TOO LARGE
310 REM HORIZONTAL VELOCITY STAYS CONSTANT IN THIS MODEL
320 REM VERTICAL VELOCITY FALLS BY GRAVITY TIMES ELAPSED TIME
330 REM KINETIC ENERGY IS REPORTED WITHOUT POTENTIAL ENERGY
340 REM USE A SMALLER STEP FOR A DENSER TRAJECTORY TABLE
350 REM MASS CHANGES ENERGY BUT DOES NOT CHANGE THE PATH
360 REM EARTH CURVATURE WIND DRAG AND LIFT ARE NOT INCLUDED
370 END

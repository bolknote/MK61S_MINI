10 REM STREAMING DESCRIPTIVE STATISTICS FOR TWENTY OBSERVATIONS
20 REM ENTER ONE VALUE AT EACH PROMPT
30 S=0:Q=0:N=0
40 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
50 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
60 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
70 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
80 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
90 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
100 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
110 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
120 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
130 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
140 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
150 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
160 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
170 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
180 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
190 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
200 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
210 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
220 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
230 INPUT "VALUE",A:S=S+A:Q=Q+A*A:N=N+1
240 M=S/N
250 V=(Q-S*S/N)/(N-1)
260 D=SQRT(V)
270 PRINT "COUNT",N
280 PRINT "SUM",S
290 PRINT "MEAN",M
300 PRINT "VARIANCE",V
310 PRINT "DEVIATION",D
320 REM THE ONE PASS FORMULA SAVES ALL INPUT VALUES
330 END
